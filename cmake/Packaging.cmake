if(CMAKE_SYSTEM_NAME STREQUAL "Darwin")
  set(AI_BRIDGE_PACKAGE_PLATFORM "macos")
elseif(WIN32)
  set(AI_BRIDGE_PACKAGE_PLATFORM "windows")
else()
  set(AI_BRIDGE_PACKAGE_PLATFORM "linux")
endif()

string(TOLOWER "${CMAKE_SYSTEM_PROCESSOR}" AI_BRIDGE_PACKAGE_ARCH)
if(AI_BRIDGE_PACKAGE_ARCH STREQUAL "")
  set(AI_BRIDGE_PACKAGE_ARCH "unknown")
endif()

set(CPACK_PACKAGE_NAME "ai_bridge")
set(CPACK_PACKAGE_VENDOR "OpenAI")
set(CPACK_PACKAGE_CONTACT "support@openai.com")
set(CPACK_PACKAGE_DESCRIPTION_SUMMARY "Cross-platform Agent Text Workspace Bridge")
set(CPACK_PACKAGE_DESCRIPTION_FILE "${CMAKE_CURRENT_SOURCE_DIR}/README.md")
set(CPACK_RESOURCE_FILE_README "${CMAKE_CURRENT_SOURCE_DIR}/README.md")
set(CPACK_PACKAGE_VERSION ${PROJECT_VERSION})
set(CPACK_PACKAGE_INSTALL_DIRECTORY "ai_bridge")
set(CPACK_PACKAGE_FILE_NAME "ai_bridge-${PROJECT_VERSION}-${AI_BRIDGE_PACKAGE_PLATFORM}-${AI_BRIDGE_PACKAGE_ARCH}")
set(CPACK_INCLUDE_TOPLEVEL_DIRECTORY ON)
set(CPACK_VERBATIM_VARIABLES ON)
set(CPACK_MONOLITHIC_INSTALL ON)

if(WIN32)
  set(AI_BRIDGE_DEFAULT_GENERATORS "ZIP;NSIS")
  set(CPACK_NSIS_DISPLAY_NAME "AI Bridge")
  set(CPACK_NSIS_PACKAGE_NAME "AI Bridge")
  set(CPACK_NSIS_ENABLE_UNINSTALL_BEFORE_INSTALL ON)
  set(CPACK_NSIS_CONTACT "support@openai.com")
  set(CPACK_NSIS_EXECUTABLES_DIRECTORY "bin")
  set(CPACK_NSIS_INSTALLED_ICON_NAME "bin\\bridge_cli.exe")
  set(CPACK_PACKAGE_EXECUTABLES "bridge_cli" "AI Bridge CLI" "bridge_daemon" "AI Bridge Daemon")
elseif(CMAKE_SYSTEM_NAME STREQUAL "Darwin")
  set(AI_BRIDGE_DEFAULT_GENERATORS "TGZ;productbuild")
  set(CPACK_SET_DESTDIR ON)
  set(CPACK_PACKAGING_INSTALL_PREFIX "/usr/local")
  set(CPACK_PRODUCTBUILD_IDENTIFIER "com.openai.ai-bridge")
  set(CPACK_PRODUCTBUILD_PACKAGE_NAME "AI Bridge")
  set(CPACK_PRODUCTBUILD_DOMAINS TRUE)
  set(CPACK_PRODUCTBUILD_BACKGROUND_ALIGNMENT center)
else()
  set(AI_BRIDGE_DEFAULT_GENERATORS "TGZ;DEB")
  set(CPACK_SET_DESTDIR ON)
  set(CPACK_PACKAGING_INSTALL_PREFIX "/usr/local")
  set(CPACK_DEBIAN_PACKAGE_MAINTAINER "OpenAI")
  set(CPACK_DEBIAN_PACKAGE_SECTION "utils")
  set(CPACK_DEBIAN_PACKAGE_PRIORITY "optional")
  set(CPACK_DEBIAN_FILE_NAME DEB-DEFAULT)
  set(CPACK_DEBIAN_PACKAGE_SHLIBDEPS OFF)
endif()

if(NOT DEFINED CPACK_GENERATOR OR CPACK_GENERATOR STREQUAL "")
  set(CPACK_GENERATOR "${AI_BRIDGE_DEFAULT_GENERATORS}")
endif()

include(CPack)
